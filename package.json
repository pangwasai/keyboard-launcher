{
  "name": "keyboard-launcher",
  "version": "1.0.0",
  "description": "A keyboard-based application launcher for Windows",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "vite build && electron-builder",
    "electron:build:win": "vite build && electron-builder --win"
  },
  "keywords": ["keyboard","launcher","electron"],
  "author": "",
  "license": "MIT",
  "dependencies": {"vue": "^3.5.39"},
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  },
  "build": {
    "appId": "com.keyboardlauncher.app",
    "productName": "KeyboardLauncher",
    "directories": {"output": "release"},
    "files": ["dist/**/*","dist-electron/**/*"],
    "win": {"target": [{"target":"nsis","arch":["x64"]}],"sign":null},
    "nsis": {"oneClick":false,"allowToChangeInstallationDirectory":true}
  }
}
